datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  email        String?  @unique
  passwordHash String
  role         String
  status       String   @default("Aktif")
  avatar       String?
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppRecord {
  id        String   @id @default(cuid())
  scope     String
  key       String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, key])
  @@index([scope])
}
